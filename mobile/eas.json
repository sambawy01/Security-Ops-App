    },
    "preview": {
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://backend-production-95c6c.up.railway.app"
      }
    },
    "preview-lan": {
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "env": {
